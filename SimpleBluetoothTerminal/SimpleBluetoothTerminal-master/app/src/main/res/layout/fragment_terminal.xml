<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#000000"
    android:padding="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">

        <TextView
            android:id="@+id/tv_esp_status"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="ESP32: Not connected"
            android:textColor="#8E8E93"
            android:fontFamily="sans-serif-medium"
            android:textSize="14sp" />

        <Button
            android:id="@+id/btn_scan_esp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:backgroundTint="#34C759"
            android:fontFamily="sans-serif-medium"
            android:text="Connect" />

        <Button
            android:id="@+id/btn_stop_ride"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:backgroundTint="#FF3B30"
            android:fontFamily="sans-serif-medium"
            android:text="Stop Ride" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">

        <LinearLayout
            android:id="@+id/tile_speed"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:background="@drawable/bg_carplay_widget"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SPEED"
                android:textColor="#8E8E93"
                android:fontFamily="sans-serif-medium"
                android:textSize="16sp"/>

            <TextView
                android:id="@+id/tv_hall"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--"
                android:textColor="#FFFFFF"
                android:fontFamily="sans-serif-black"
                android:textSize="64sp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MPH"
                android:textColor="#8E8E93"
                android:fontFamily="sans-serif-medium"
                android:textSize="16sp"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/tile_incline"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:background="@drawable/bg_carplay_widget"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="INCLINE"
                android:textColor="#8E8E93"
                android:fontFamily="sans-serif-medium"
                android:textSize="16sp"/>

            <TextView
                android:id="@+id/tv_accel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--"
                android:textColor="#0A84FF"
                android:fontFamily="sans-serif-black"
                android:textSize="56sp"/>
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="0.8"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">

        <TextView
            android:id="@+id/tv_heart_rate"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:background="@drawable/bg_carplay_widget"
            android:gravity="center"
            android:text="❤️ HR\n--\nbpm"
            android:textColor="#FF453A"
            android:fontFamily="sans-serif-medium"
            android:textSize="22sp" />

        <TextView
            android:id="@+id/tv_calories"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:layout_marginStart="6dp"
            android:background="@drawable/bg_carplay_widget"
            android:gravity="center"
            android:text="🔥 Cals\n--\nkcal"
            android:textColor="#FF9F0A"
            android:fontFamily="sans-serif-medium"
            android:textSize="22sp" />

        <TextView
            android:id="@+id/tv_distance"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:background="@drawable/bg_carplay_widget"
            android:gravity="center"
            android:text="📍 Dist\n--\nmi"
            android:textColor="#32ADE6"
            android:fontFamily="sans-serif-medium"
            android:textSize="22sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/music_controls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_carplay_widget"
        android:orientation="vertical"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <androidx.cardview.widget.CardView
                android:layout_width="72dp"
                android:layout_height="72dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#3A3A3C">

                <ImageView
                    android:id="@+id/iv_album_art"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop" />
            </androidx.cardview.widget.CardView>

            <TextView
                android:id="@+id/tv_track_info"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="16dp"
                android:ellipsize="marquee"
                android:singleLine="true"
                android:text="Not Playing"
                android:textColor="#FFFFFF"
                android:fontFamily="sans-serif-medium"
                android:textSize="24sp" />
        </LinearLayout>

        <SeekBar
            android:id="@+id/seek_bar_audio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:progressTint="#FFFFFF"
            android:thumbTint="#FFFFFF" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn_prev"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_marginEnd="32dp"
                android:backgroundTint="#3A3A3C"
                android:text="⏮"
                android:textSize="20sp" />

            <Button
                android:id="@+id/btn_play_pause"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:backgroundTint="#FFFFFF"
                android:textColor="#000000"
                android:text="⏯"
                android:textSize="28sp" />

            <Button
                android:id="@+id/btn_next"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_marginStart="32dp"
                android:backgroundTint="#3A3A3C"
                android:text="⏭"
                android:textSize="20sp" />
        </LinearLayout>
    </LinearLayout>

    <TextView android:id="@+id/receive_text" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
    <TextView android:id="@+id/send_text" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>

</LinearLayout>